{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Token Deck",
  "version": "0.1.0",
  "identifier": "app.tokendeck.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Token Deck",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.supabase.co https://api.openai.com https://api.anthropic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "AI 코딩 도구 토큰 사용량 통합 대시보드"
  }
}
